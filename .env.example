# ============ ВЫБОР МЕТОДА РАБОТЫ БОТА ============
# Установите один из методов:
# - longpoll    : LongPollAPI (длительное опрашивание)
# - callback    : CallbackAPI (Webhook) - рекомендуется для production
# Если переменная не установлена, будет интерактивный выбор при запуске
POLLING_METHOD=callback

# ============ WEBHOOK (CallbackAPI) ============
# Обязательно, если используется режим callback
# Публичный URL вашего сервера (пример: https://example.com или https://123.456.789.012)
BASE_URL=https://example.com

# Опционально, по умолчанию 0.0.0.0
WEBHOOK_HOST=0.0.0.0

# Опционально, по умолчанию 8080
WEBHOOK_PORT=8080

# Опционально, по умолчанию /
WEBHOOK_PATH=/

# Опционально, но рекомендуется для безопасности
# Используется для проверки подлинности запросов от VK
WEBHOOK_SECRET=your_secret_key_here

# ============ БД И ТОКЕНЫ ============
# Эти значения уже установлены в globals.py, но можете переопределить здесь если нужно
# DB_URL=postgresql+psycopg://user:password@localhost:5432/vkr_bot
# BOT_TOKEN=vk1.a.xxxxxx...
# SERVICE_TOKEN=xxxxxx...
